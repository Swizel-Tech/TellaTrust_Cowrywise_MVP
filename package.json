{
  "name": "tellavault",
  "version": "0.1.0",
  "private": true,
  "description": "TellaTrust — savings & investment platform prototype (Swizel Technologies Limited)",
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:web": "npm run dev -w apps/web",
    "dev:admin": "npm run dev -w apps/admin",
